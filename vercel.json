{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "api/*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "ajax/*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    {
      "src": "/(.*\\.php)$",
      "dest": "/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1.php"
    }
  ]
}
